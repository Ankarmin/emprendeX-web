{
  "name": "emprendeX",
  "private": true,
  "scripts": {
    "build:api": "pnpm --filter ./apps/api build",
    "build": "pnpm exec turbo run build",
    "check-types:api": "pnpm --filter ./apps/api check-types",
    "dev:api": "pnpm --filter ./apps/api dev",
    "dev:stack": "node scripts/dev-local.mjs",
    "dev:share": "pnpm dev:stack",
    "dev:turbo": "pnpm exec turbo run dev",
    "dev": "pnpm dev:stack",
    "docker:api": "docker compose --env-file apps/api/.env.local up --build",
    "docker:api:detached": "docker compose --env-file apps/api/.env.local up --build -d",
    "docker:down": "docker compose --env-file apps/api/.env.local down",
    "docker:logs": "docker compose --env-file apps/api/.env.local logs -f",
    "docker:up": "docker compose --env-file apps/api/.env.local up --build",
    "docker:up:detached": "docker compose --env-file apps/api/.env.local up --build -d",
    "format:check": "prettier --check \"package.json\" \"pnpm-workspace.yaml\" \"turbo.json\" \"docker-compose.yaml\" \".github/**/*.yml\" \"apps/api/**/*.{ts,json,md}\" \"apps/web/**/*.{ts,tsx,js,jsx,json,md}\"",
    "lint": "pnpm exec turbo run lint",
    "lint:api": "pnpm --filter ./apps/api lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "start:api": "pnpm --filter ./apps/api start",
    "test:api": "pnpm --filter ./apps/api test",
    "test:api:ci": "pnpm --filter ./apps/api test:ci",
    "test:api:e2e": "pnpm --filter ./apps/api test:e2e",
    "test:web": "pnpm --filter ./apps/web test",
    "test:web:ci": "pnpm --filter ./apps/web test:ci",
    "test": "pnpm exec turbo run test",
    "check-types": "pnpm exec turbo run check-types",
    "postinstall": "node scripts/install-mobile.mjs"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.14",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=18"
  }
}
