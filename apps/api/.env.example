DATABASE_TARGET=auto

# Railway/Postgres URL directa.
# En Railway se prioriza DATABASE_URL interno y luego DATABASE_PUBLIC_URL.
DATABASE_URL=
DATABASE_PUBLIC_URL=

# Fallback local para docker/postgres.
PORT=3000
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=emprendex
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
DATABASE_SSL=false
JWT_SECRET=replace-this-with-a-long-random-secret
JWT_EXPIRES_IN=86400
CORS_ORIGINS=http://localhost:8081,http://localhost:19006
APP_PUBLIC_URL=http://localhost:${PORT}
