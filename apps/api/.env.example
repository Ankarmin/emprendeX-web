# Requerido — string de conexión a PostgreSQL
DATABASE_PUBLIC_URL=postgresql://postgres:password@localhost:5433/emprendex

# Requerido — mínimo 16 caracteres
# En Railway: generar en el dashboard con `openssl rand -hex 32`
JWT_SECRET=dev-secret-change-in-production-abc123

# ── Railway — configurar en el dashboard ─────────────────────
# DATABASE_PUBLIC_URL → lo asigna Railway automáticamente
# DATABASE_SSL=true
# CORS_ORIGINS=https://emprendex.vercel.app
# WEB_PUBLIC_URL=https://emprendex.vercel.app
