# ============================================================
# LOCAL — Docker (copiar a .env.local y ejecutar pnpm dev)
# ============================================================
DATABASE_PUBLIC_URL=postgresql://postgres:password@localhost:5433/emprendex
DATABASE_SSL=false
CORS_ORIGINS=http://localhost:3001,http://localhost:8081,http://localhost:19006
WEB_PUBLIC_URL=http://localhost:3001

# ============================================================
# RAILWAY — Producción (configurar en el dashboard de Railway)
# ============================================================
# Railway asigna DATABASE_URL, DATABASE_PUBLIC_URL y RAILWAY_PUBLIC_DOMAIN automáticamente.
# Deja DATABASE_URL vacío. Solo necesitas configurar:
#
#   DATABASE_SSL=true
#   JWT_SECRET=<generar secreto aleatorio de 64+ caracteres>
#   CORS_ORIGINS=https://emprendex.vercel.app
#   WEB_PUBLIC_URL=https://emprendex.vercel.app
#   API_URL=https://<tu-app>.up.railway.app  (opcional, se autodetecta con RAILWAY_PUBLIC_DOMAIN)
#
# Opcional si usas Turnstile:
#   PUBLIC_CATALOG_TURNSTILE_SECRET_KEY=<tu-secret-key>

# ── Base de datos ────────────────────────────────────────────
DATABASE_URL=
DATABASE_TARGET=auto

# ── Servidor ─────────────────────────────────────────────────
PORT=3000
API_URL=http://localhost:3000

# ── Swagger / OpenAPI ─────────────────────────────────────────
# Ruta donde se sirve Swagger UI (relativa al prefijo global "api")
SWAGGER_DOCS_PATH=api/docs

# ── Autenticación JWT ────────────────────────────────────────
JWT_SECRET=replace-this-with-a-long-random-secret
JWT_EXPIRES_IN=86400

# ── Rate limiting — Catálogo público ─────────────────────────
PUBLIC_CATALOG_READ_TTL_MINUTES=1
PUBLIC_CATALOG_READ_LIMIT=60
PUBLIC_CATALOG_SUBMIT_TTL_MINUTES=10
PUBLIC_CATALOG_SUBMIT_LIMIT=5
PUBLIC_CATALOG_MAX_ITEMS=25
PUBLIC_CATALOG_MAX_ITEM_QUANTITY=100

# ── Turnstile (Cloudflare) — Opcional ────────────────────────
PUBLIC_CATALOG_TURNSTILE_SECRET_KEY=
