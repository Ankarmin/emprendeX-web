# ============================================================
# LOCAL (copiar a .env.local y ejecutar pnpm dev)
# ============================================================
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1

# ============================================================
# VERCEL — Producción (configurar en Settings > Environment Variables)
# ============================================================
# NEXT_PUBLIC_API_BASE_URL=https://api-production-xxxx.up.railway.app/api/v1
#
# Opcional si usas Turnstile:
#   NEXT_PUBLIC_TURNSTILE_SITE_KEY=<tu-site-key>

# ── Desarrollo local ─────────────────────────────────────────
NEXT_ALLOWED_DEV_ORIGINS=

# ── Moneda ───────────────────────────────────────────────────
NEXT_PUBLIC_DEFAULT_CURRENCY_SYMBOL=S/

# ── Turnstile (Cloudflare) — Opcional ────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
